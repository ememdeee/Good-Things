{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "acf/content-slider",
	"title": "Text Content Slider",
	"description": "A Text Content Slider with title, text, and button on each slide.",
	"category": "theme-blocks",
	"icon": "image-flip-horizontal",
	"keywords": ["slider", "content", "text"],
	"editorScript": "file:./js/content-slider-editor.min.js",
	"editorStyle":  "file:./css/content-slider.css",
	"viewScript": "file:./js/content-slider.min.js",
	"style":  "file:./css/content-slider.css",
	"acf": {
		"mode": "preview",
		"renderTemplate": "/blocks/content-slider/content-slider.php"
	},
	"supports": {
		"align": false,
		"mode": true,
		"customClassName": false
	},
	"example": {
		"attributes": {
			"title_text": "Text Content Slider Preview"
		}
	},
	"render": "/blocks/content-slider/content-slider.php"
}