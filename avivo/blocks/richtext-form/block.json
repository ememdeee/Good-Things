{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "acf/richtext-form",
	"title": "Rich Text & Form",
	"description": "Rich Text & Form block with title, text, and form.",
	"category": "theme-blocks",
	"icon": "align-right",
	"keywords": ["content", "richtext", "form", "rich text"],
	"editorScript": "file:./js/richtext-form-editor.min.js",
	"editorStyle":  "file:./css/richtext-form-editor.css",
	"viewScript": "file:./js/richtext-form.min.js",
	"style":  "file:./css/richtext-form.css",
	"acf": {
		"mode": "preview",
		"renderTemplate": "/blocks/richtext-form/richtext-form.php"
	},
	"supports": {
		"align": false,
		"mode": true,
		"customClassName": false
	},
	"example": {
		"attributes": {
			"title_text": "Rich Text & Form Preview"
		}
	},
	"render": "/blocks/richtext-form/richtext-form.php"
}
