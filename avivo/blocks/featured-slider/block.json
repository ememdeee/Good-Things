{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "acf/featured-slider",
	"title": "Featured Slider",
	"description": "A Featured Slider with background image, title, text, and button on each slide.",
	"category": "theme-blocks",
	"icon": "cover-image",
	"keywords": ["slider", "content", "text", "hero"],
	"editorScript": "file:./js/featured-slider-editor.min.js",
	"editorStyle":  "file:./css/featured-slider-editor.css",
	"viewScript": "file:./js/featured-slider.min.js",
	"viewStyle":  "file:./css/featured-slider.css",
	"acf": {
		"mode": "preview",
		"renderTemplate": "/blocks/featured-slider/featured-slider.php"
	},
	"supports": {
		"align": false,
		"mode": true,
		"customClassName": false
	},
	"example": {
		"attributes": {
			"title_text": "Featured Slider Preview"
		}
	},
	"render": "/blocks/featured-slider/featured-slider.php"
}